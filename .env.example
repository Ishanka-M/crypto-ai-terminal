# ============================================
# Crypto Trading System - Environment Config
# ============================================
# Copy this file to .env and fill in your keys

# Binance API (https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=True  # Set False for real trading

# Telegram Alerts (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Email Alerts
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECEIVER=receiver@gmail.com

# App Settings
LOG_LEVEL=INFO
DEMO_MODE=True  # True = use fake data (no API needed for testing)
